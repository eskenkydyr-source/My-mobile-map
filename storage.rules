rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Граф JSON — читать все, писать только авторизованные
    match /graph/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024  // макс 50 MB
                   && request.resource.contentType == 'application/json';
    }

    // Всё остальное — запрещено
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
