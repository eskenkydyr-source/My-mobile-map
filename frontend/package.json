{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://eskenkydyr-source.github.io/kalamkas-app",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:firebase": "cross-env FIREBASE=true tsc -b && cross-env FIREBASE=true vite build",
    "build:mobile": "CAPACITOR=true tsc -b && CAPACITOR=true vite build && npx cap sync android",
    "lint": "eslint .",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "deploy:firebase": "npm run build:firebase && cd .. && npx firebase deploy --only hosting",
    "deploy:all": "npm run deploy && npm run deploy:firebase"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@types/leaflet": "^1.9.14",
    "firebase": "^12.11.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
